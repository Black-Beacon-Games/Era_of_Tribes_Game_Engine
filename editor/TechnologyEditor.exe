@echo off
REM Era of Tribes - Technologie-Editor (Wrapper)
REM Erstellt und bearbeitet Technologiebaeume, Era-Stufen und Effekte.

echo ============================================
echo  Era of Tribes - Technologie-Editor v1.0.0
echo ============================================
echo.
echo  Funktionen:
echo   - Technologie anlegen/bearbeiten
echo   - Era zuweisen (Bronze, Eisen, Mittelalter)
echo   - Kosten und Forschungszeit festlegen
echo   - Voraussetzungen (Tree) definieren
echo   - Effekte zuweisen
echo   - Export nach game/technologies/
echo.
echo  [EDITOR GESTARTET]
:loop
timeout /t 1 /nobreak >nul
goto loop
